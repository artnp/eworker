"Set fso = CreateObject(\"Scripting.FileSystemObject\")\nSet WshShell = CreateObject(\"WScript.Shell\")\n\n' กำหนดพาธต่างๆ แบบ Dynamic\nbotDir = fso.GetParentFolderName(WScript.ScriptFullName)\neworkerDir = fso.GetParentFolderName(botDir)\nwatcherScript = eworkerDir & \"\\auto_donate_watcher.py\"\nlogFile = botDir & \"\\bot.log\"\n\n' 1. ตรวจสอบว่า auto_donate_watcher.py ทำงานอยู่หรือไม่ (ป้องกันการรันซ้ำ)\nDim isRunning\nisRunning = False\n\nOn Error Resume Next\nSet objWMIService = GetObject(\"winmgmts:\\\\.\\root\\cimv2\")\nIf Err.Number = 0 Then\n    Set colItems = objWMIService.ExecQuery(\"Select * from Win32_Process Where Name = 'pythonw.exe' OR Name = 'python.exe'\")\n    For Each objItem in colItems\n        If InStr(LCase(objItem.CommandLine), \"auto_donate_watcher.py\") > 0 Then\n            isRunning = True\n            Exit For\n        End If\n    Next\nEnd If\nOn Error GoTo 0\n\n' ถ้ายืนยันว่ายังไม่ได้รัน ให้เริ่มรันใน Background แบบไม่มีหน้าต่าง (ใช้ pythonw)\nIf Not isRunning Then\n    WshShell.Run \"pythonw \"\"\" & watcherScript & \"\"\"\", 0, False\nEnd If\n\n' 2. รัน node bot.js แบบซ่อนหน้าต่าง และรอจนกว่าจะรันเสร็จ (WaitOnReturn = True)\nintExitCode = WshShell.Run(\"cmd /c cd /d \"\"\" & botDir & \"\"\" && node bot.js\", 0, True)\n\n' 3. ตรวจสอบสถานะการทำงาน\nIf intExitCode <> 0 Then\n    ' หากมี Error (Exit code ไม่ใช่ 0) ดึงข้อมูล log ล่าสุดมาแสดง Notification และ Dialog Box\n    psCommand = \"powershell -WindowStyle Hidden -Command \"\"\" & _\n        \"$logFile = '\" & logFile & \"'; \" & _\n        \"if (Test-Path $logFile) { \" & _\n        \"  $lines = Get-Content $logFile -Tai
